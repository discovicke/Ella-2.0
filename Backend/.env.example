# --- Database Settings ---
# Options: sqlite, postgres, sqlserver
DatabaseSettings__Provider=sqlite
# Example for SQLite: Data Source=ellaDB.sqlite
# Example for Postgres: Host=localhost;Database=ella;Username=postgres;Password=...
DatabaseSettings__ConnectionString=Data Source=ellaDB.sqlite

# --- JWT Settings ---
# WARNING: Change this secret in your local .env file! Do not use this default.
JwtSettings__SecretKey=REPLACE_WITH_YOUR_OWN_SECRET_KEY_AT_LEAST_32_CHARS
JwtSettings__Issuer=EllaBookingAPI
JwtSettings__Audience=EllaBookingClient
JwtSettings__AccessTokenExpirationMinutes=60