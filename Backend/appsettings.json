{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "DatabaseSettings": {
    "Provider": "sqlite",
    "ConnectionString": "Data Source=app/Infrastructure/Data/ellaDB.sqlite"
  },
  "JwtSettings": {
    "SecretKey": "CHANGE_THIS_IN_PRODUCTION_USE_AT_LEAST_32_CHARACTERS_FOR_SECURITY",
    "Issuer": "EllaBookingAPI",
    "Audience": "EllaBookingClient",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  }
}