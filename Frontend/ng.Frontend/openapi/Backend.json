  "components": {
    "schemas": {
      "AssetTypeResponseDto": {
        "required": [
          "id",
          "description"
        ],
        "type": "object",
        "properties": {
          "id": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int64"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "BannedStatus": {
        "enum": [
          "NotBanned",
          "Banned"
        ]
      },
      "BookingDetailedReadModel": {
        "type": "object",
        "properties": {
          "bookingId": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int64"
          },
          "userId": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int64"
          },
          "userName": {
            "type": [
              "null",
              "string"
            ]
          },
          "userEmail": {
            "type": [
              "null",
              "string"
            ]
          },
          "userRole": {
            "$ref": "#/components/schemas/UserRole"
          },
          "userClass": {
            "type": [
              "null",
              "string"
            ]
          },
          "roomId": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int64"
          },
          "roomName": {
            "type": [
              "null",
              "string"
            ]
          },
